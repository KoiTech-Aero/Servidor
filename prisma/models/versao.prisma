model Versao {
  id_norma        String   @db.VarChar(255)
  versao_numero   String   @db.VarChar(255)
  descricao       String   @db.VarChar(255)
  data_publicacao DateTime @default(now()) @db.Date
  path_file       String   @db.Text
  status          Boolean  @default(false) @db.Boolean
  
  //Relacionamento com norma
  norma           Norma    @relation(fields: [id_norma], references: [codigo])
  
  //Relacionamento com nota
  notas Nota[]


  @@id(name: "versaoId", fields:[id_norma, versao_numero])
}
