model Norma {
  id             String @id @default(uuid())
  codigo         String @unique @db.VarChar(255)
  titulo         String @db.VarChar(100)
  area_tecnica   String @db.VarChar(50)
  orgao_emissor  String @db.VarChar(50)
  id_solicitacao String @unique
  solicitacao    Solicitacao @relation(fields: [id_solicitacao], references: [id])
}
