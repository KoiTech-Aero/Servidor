model Norma {
  id            String @id @default(uuid())
  codigo        String @unique @db.VarChar(255)
  titulo        String @db.VarChar(100)
  escopo        String @db.Text
  area_tecnica  String @db.VarChar(50)
  orgao_emissor String @db.VarChar(50)

  // Relacionamentos
  versoes       Versao[]
  tags          NormasTags[]
  referencias   NormaReferencia[] @relation("NormaReferencia")
  referenciadas NormaReferencia[] @relation("NormaReferenciada")
}
