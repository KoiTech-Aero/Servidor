{
  "name": "aero",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "cli": "node src/cli.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit src/server.ts",
    "test": "tsc && npm run db:up && concurrently \"npm run start:watch\" \"npx wait-on http://localhost:3000/health && npx vitest\"",
    "start:watch": "tsc && node --watch dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:up": "docker compose -f infra/compose.yaml up -d && npm run wait-for-postgres && npm run migrate",
    "db:stop": "docker compose -f infra/compose.yaml stop",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "migrate": "npx prisma migrate dev && npx prisma generate dev",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "cripto": "^1.1.4",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/inquirer": "^9.0.9",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "inquirer": "^13.3.2",
    "zod": "^4.3.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}