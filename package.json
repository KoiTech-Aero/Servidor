{
  "name": "aero",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "NODE_ENV=test tsc && npm run db:up && npm run wait-for-postgres && concurrently \"npm run start:watch\" \"npx wait-on http://localhost:3000/health && npx vitest\"",
    "build": "tsc",
    "start:watch": "NODE_ENV=test node --watch dist/server.js",
    "dev": "NODE_ENV=test tsx watch src/server.ts",
    "type-check": "tsc --noEmit src/server.ts",
    "db:up": "docker compose -f infra/compose.yaml up -d",
    "db:stop": "docker compose -f infra/compose.yaml stop",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "cripto": "^1.1.4",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.3.6"
  }
}